// Production PostgreSQL schema (used by Dockerfile / Railway).
// Local dev continues to use schema.prisma (SQLite).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile UserProfile?
  images  UserImage[]
  tryOns  TryOn[]
  closetItems ClosetItem[]
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age             Int?
  sex             String?
  heightCm        Float?
  weightKg        Float?
  bodyType        String?
  preferredFit    String?
  braSize         String?
  jeanSize        String?
  pantWaist       String?
  pantInseam      String?
  dressSize       String?
  shoeSize        String?
  underwearSize   String?
  shirtSize       String?
  jacketSize      String?
  bustCm          Float?
  waistCm         Float?
  hipsCm          Float?
  shoulderWidthCm Float?
  fitNotes        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserImage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl  String
  angle     String
  createdAt DateTime @default(now())
}

model Product {
  id             String   @id @default(cuid())
  url            String?
  brand          String?
  title          String
  price          String?
  currency       String?
  description    String?
  category       String?
  images         String   @default("[]")
  availableSizes String   @default("[]")
  colors         String   @default("[]")
  material       String?
  fitDescription String?
  modelInfo      String?
  reviewsSummary String?
  rawScrapedText String?
  createdAt      DateTime @default(now())

  tryOns TryOn[]
}

model TryOn {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
  selectedSize    String?
  selectedColor   String?
  userNotes       String?
  status          String   @default("pending")
  generatedImages String   @default("[]")
  fitPrediction   String?
  recommendedSize String?
  confidence      Float?
  fitExplanation  String?
  fitWarnings     String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  kind            String   @default("single")

  parentId        String?
  parent          TryOn?   @relation("TryOnVariations", fields: [parentId], references: [id], onDelete: Cascade)
  variations      TryOn[]  @relation("TryOnVariations")
  variationPrompt String?

  closetSource ClosetItem?
  outfitItems  OutfitTryOnItem[] @relation("OutfitItems")
}

model ClosetItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tryOnId   String   @unique
  tryOn     TryOn    @relation(fields: [tryOnId], references: [id], onDelete: Cascade)
  label     String?
  createdAt DateTime @default(now())

  outfitLinks OutfitTryOnItem[]
}

model OutfitTryOnItem {
  id            String     @id @default(cuid())
  outfitTryOnId String
  outfitTryOn   TryOn      @relation("OutfitItems", fields: [outfitTryOnId], references: [id], onDelete: Cascade)
  closetItemId  String
  closetItem    ClosetItem @relation(fields: [closetItemId], references: [id], onDelete: Restrict)

  @@unique([outfitTryOnId, closetItemId])
}
