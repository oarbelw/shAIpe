# Local development (SQLite)
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL — set this on Railway, not locally)
# DATABASE_URL="postgresql://user:pass@host:5432/shaipe"

# Google Gemini (required for real try-on generation)
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Optional: higher rate limits for the product-page reader proxy (r.jina.ai)
# that lets bot-protected stores (Aritzia, Zara, etc.) be read in production.
# Works without a key at a lower rate limit. Get one free at https://jina.ai/reader
JINA_API_KEY=

# Who can sign in (comma-separated). Built-in list also includes oarbelw@gmail.com and jennamaya.c@gmail.com
AUTHORIZED_EMAILS=oarbelw@gmail.com,jennamaya.c@gmail.com

# Where uploaded images are stored (Railway volume mount: /app/uploads)
# UPLOADS_DIR=uploads
